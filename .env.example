# ─── Required ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get free at console.groq.com — free, ultra-fast, no rate limits on standard use
GROQ_API_KEY=your_groq_api_key_here

# ─── GitHub (optional but recommended) ────────────────────────────────────────
# GitHub → Settings → Developer settings → Personal access tokens → repo scope
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup): sqlite+aiosqlite:///./replitai.db
# PostgreSQL: postgresql+asyncpg://user:pass@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./replitai.db

# ─── WebApp (optional) ────────────────────────────────────────────────────────
# Your public HTTPS URL for the Telegram WebApp
# Example: https://myapp.railway.app
WEBAPP_URL=
WEBAPP_PORT=8080

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789,987654321
